with
    sent as (
        select
            user_id_sender,
            user_id_receiver,
            date as fin_date,
            action as sent
        from
            fb_friend_requests
        where
            action = 'sent'
    ),
    accepted as (
        select
            user_id_sender,
            user_id_receiver,
            date as discard_date,
            action as accepted
        from
            fb_friend_requests
        where
            action = 'accepted'
    ),
    sent_accepted as (
        select
            s.user_id_sender as user_id_sender,
            s.user_id_receiver as user_id_receiver,
            s.fin_date as fin_date,
            s.sent as sent,
            a.discard_date as discard_date,
            a.accepted as accepted
        from
            sent as s
            left join accepted as a on s.user_id_sender = a.user_id_sender
    ),
    add_numbers as (
        select
            user_id_receiver,
            fin_date,
            sent,
            case
                when sent = 'sent' then 1
                else 0
            end as sent_num,
            discard_date,
            accepted,
            case
                when accepted = 'accepted' then 1
                else 0
            end as accepted_num
        from
            sent_accepted
    ),
    agg_counts as (
        select
            fin_date as date,
            sum(sent_num) as sent_count,
            sum(accepted_num) as accepted_count
        from
            add_numbers
        group by
            date
    )
select
    date,
    accepted_count / sent_count as ratio
from
    agg_counts