class Solution:
    def twoSum(self, nums: List[int], target: int) -> List[int]:
        for i in range(len(nums)):
            firstnum = nums[i]
            secondnums = nums[:i] + nums[(i+1):]
            for j in range(len(secondnums)):
                secondnum = secondnums[j]
                tempsum = firstnum + secondnum
                if tempsum == target:
                    return([i, j + 1])