class Solution:
    def isValid(self, s: str) -> bool:
        stack = []
        reverse_stack = []
        bracket_pairs = {
            '(': ')',
            '[': ']',
            '{': '}'
        }

        for bracket in s:
            if bracket in bracket_pairs.keys():
                stack.append(bracket)
            elif bracket in bracket_pairs.values():
                if len(stack) == 0:
                    return(False)
                elif bracket == bracket_pairs[stack[(len(stack) - 1):][0]]:
                    stack = stack[:-1]
                else:
                    return(False)

        return(stack == [])

