# Definition for a binary tree node.
# class TreeNode:
#     def __init__(self, val=0, left=None, right=None):
#         self.val = val
#         self.left = left
#         self.right = right
class Solution:
    def isValidBST(self, root: Optional[TreeNode]) -> bool:
        def isValidLevel(newroot, l, r):
            if newroot is None:
                return(True)
            elif not (newroot.val < r and newroot.val > l):
                return(False)
            return(isValidLevel(newroot.left, l, newroot.val) and isValidLevel(newroot.right, newroot.val, r))
        return(isValidLevel(root, float('-inf'), float('inf')))

