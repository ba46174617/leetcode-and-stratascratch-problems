with
    a as (
        select
            *,
            row_number() over (
                partition by
                    player_id
                order by
                    match_date
            ) as rn
        from
            players_results
    ),
    b as (
        select
            *,
            rn - row_number() over (
                partition by
                    player_id
                order by
                    match_date
            ) as rn_diff -- turns out in this case the where clause is executed before the new row_number is assigned
        from
            a
        where
            match_result = 'W'
    ),
    c as (
        select
            player_id,
            count(*) as winning_streak
        from
            b
        group by
            player_id,
            rn_diff
    ),
    d as (
        select
            *,
            dense_rank() over (
                order by
                    winning_streak desc
            ) as rnk
        from
            c
    )
select
    player_id,
    winning_streak
from
    d
where
    rnk = 1
