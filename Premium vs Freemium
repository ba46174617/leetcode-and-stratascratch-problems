with
    downloads as (
        select
            d.date as download_date,
            p.paying_customer as paying_customer,
            sum(d.downloads) as no_downloads
        from
            ms_download_facts as d
            left join ms_user_dimension as u on d.user_id = u.user_id
            left join ms_acc_dimension as p on u.acc_id = p.acc_id
        group by
            d.date,
            p.paying_customer
        order by
            d.date asc
    ),
    pay_non_pay as (
        select
            download_date,
            sum(
                case
                    when paying_customer = 'no' then no_downloads
                    else 0
                end
            ) as non_paying,
            sum(
                case
                    when paying_customer = 'yes' then no_downloads
                    else 0
                end
            ) as paying
        from
            downloads
        group by
            download_date
    )
select
    *
from
    pay_non_pay
where
    non_paying > paying