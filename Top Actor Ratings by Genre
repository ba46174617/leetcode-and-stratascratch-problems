with
    all_genres as (
        select
            actor_name,
            genre,
            count(*) as number_of_movies_in_genre,
            avg(movie_rating) as average_movie_rating,
            dense_rank() over (
                partition by
                    actor_name
                order by
                    count(*) desc,
                    avg(movie_rating) desc
            ) as rnk
        from
            top_actors_rating
        group by
            actor_name,
            genre
        order by
            actor_name,
            genre,
            count(*) desc,
            avg(movie_rating) desc
    ),
    ranked_actors as (
        select
            actor_name,
            genre,
            average_movie_rating,
            rnk,
            dense_rank() over (
                order by
                    average_movie_rating desc
            ) as new_rnk
        from
            all_genres
        where
            rnk = 1
        order by
            average_movie_rating desc
    )
select
    actor_name,
    genre,
    average_movie_rating,
    new_rnk
from
    ranked_actors
where
    new_rnk <= 3